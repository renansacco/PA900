  chart {
    id			    108
    machine		    1
    name		    "LQR - Entry Straight/MATLAB Function1"
    windowPosition	    [422 539.941 189 413]
    viewLimits		    [0 156.75 0 153.75]
    screen		    [1 1 3600 1200 1.180555555555556]
    treeNode		    [0 109 0 0]
    viewObj		    108
    ssIdHighWaterMark	    6
    decomposition	    CLUSTER_CHART
    type		    EML_CHART
    chartFileNumber	    21
    disableImplicitCasting  1
    eml {
      name		      "Angular_Error"
    }
    firstData		    110
    firstTransition	    114
    firstJunction	    113
  }
  state {
    id			    109
    labelString		    "eML_blk_kernel()"
    position		    [18 64.5 118 66]
    fontSize		    12
    chart		    108
    treeNode		    [108 0 0 0]
    superState		    SUBCHART
    subviewer		    108
    ssIdNumber		    1
    type		    FUNC_STATE
    decomposition	    CLUSTER_STATE
    eml {
      isEML		      1
      script		      "% ref-meas\nfunction ang_error = Angular_Error(ref, meas)\n\n    ref = mod(ref, 2*pi);\n    meas "
      "= mod(meas, 2*pi);\n    \n    if(meas > ref)\n        if(abs(2*pi-meas+ref) < abs(ref-meas))\n            ang_er"
      "ror = 2*pi-meas+ref;\n        else\n            ang_error = ref - meas;\n        end\n    elseif (meas < ref)\n "
      "       if(abs(meas - ref) < abs(2*pi-ref+meas))\n            ang_error = ref - meas;\n        else\n            "
      "ang_error = -(meas + 2*pi - ref);\n        end\n    else\n        ang_error = single(0);\n    end\nend"
      editorLayout	      "100 M4x1[10 5 700 500]"
    }
  }
