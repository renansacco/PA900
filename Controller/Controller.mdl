    eml {
      isEML		      1
      script		      "% et: erro (ref-meas)\n% B: Parâmetro 3\n% ur: Parâmetro 2 (batentes do controle)\n% er: Parâmetr"
      "o\nfunction u = CME(et, B, ur, er)\n\n\numin = ur(1); umax = ur(2);\n% Cálculo do erro\n%et = yref - y;\n\ne = e"
      "t / er;\n\nif e < -1\n    e = single(-1);\nelseif e > 1\n    e = single(1);\nend\n\n% Cálculo de u\nif abs(e) =="
      " 1\n    ut = e;\nelse\n    ss = e - sign(e);\n    ut = sign(ss) * (abs(ss) ^ (2 ^ -B) - 1);\nend\n\n% Cálculo da"
      " saída\na = (umax - umin) / 2; u = a * (ut - 1) + umax;\n\nend"
      editorLayout	      "100 M4x1[10 5 700 500]"
    }
  }
