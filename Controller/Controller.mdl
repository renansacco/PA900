  chart {
    id			    90
    machine		    1
    name		    "MATLAB Function1"
    windowPosition	    [422 539.941 189 413]
    viewLimits		    [0 156.75 0 153.75]
    screen		    [1 1 3600 1200 1.180555555555556]
    treeNode		    [0 91 0 0]
    viewObj		    90
    ssIdHighWaterMark	    9
    decomposition	    CLUSTER_CHART
    type		    EML_CHART
    chartFileNumber	    9
    disableImplicitCasting  1
    eml {
      name		      "fcn"
    }
    firstData		    92
    firstTransition	    97
    firstJunction	    96
  }
  state {
    id			    91
    labelString		    "eML_blk_kernel()"
    position		    [18 64.5 118 66]
    fontSize		    12
    chart		    90
    treeNode		    [90 0 0 0]
    superState		    SUBCHART
    subviewer		    90
    ssIdNumber		    1
    type		    FUNC_STATE
    decomposition	    CLUSTER_STATE
    eml {
      isEML		      1
      script		      "function flagSaturation = fcn( thetaRad, omegaTarget, steerCalibration)\n\nflagSaturation = false"
      ";\n\npersistent rigthSaturation leftSaturation\n\nif(isempty(rigthSaturation))\n    rigthSaturation = false;\nen"
      "d\n\nif(isempty(leftSaturation))\n    leftSaturation = false;\nend\n\n\nif(steerCalibration.isCalibrated)\n    \n"
      "    % Relé da Saturação a direita\n    % Menor o valor, mais a direita a roda está\n    if(rigthSaturation)\n   "
      "     if(thetaRad > (steerCalibration.rightValue + steerCalibration.deadZone))\n            rigthSaturation = fal"
      "se;\n        end\n    else\n        if(thetaRad < steerCalibration.rightValue)\n            rigthSaturation = tr"
      "ue;\n        end\n    end\n    \n    % Relé da Saturação a esquerda\n    % quanto maior o valor, mais a esquerda"
      " a roda está\n    if(leftSaturation)\n\n        if(thetaRad < (steerCalibration.leftValue - steerCalibration.dea"
      "dZone))\n            leftSaturation = false;\n        end\n    else\n        if(thetaRad > steerCalibration.left"
      "Value)\n            leftSaturation = true;\n        end\n    end\n    \n    \n    % Desliga a velocidade angular"
      " conforme saturação e sinal\n    if((rigthSaturation && omegaTarget<0) || (leftSaturation && omegaTarget>0))\n  "
      "      flagSaturation = true;\n    end\n\nend\n\n\nend\n"
      editorLayout	      "100 M4x1[10 5 700 500]"
    }
  }
