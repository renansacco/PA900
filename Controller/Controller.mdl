  chart {
    id			    50
    machine		    1
    name		    "Controle_Curva/CME1"
    windowPosition	    [422 539.941 189 413]
    viewLimits		    [0 156.75 0 153.75]
    screen		    [1 1 3600 1200 1.180555555555556]
    treeNode		    [0 51 0 0]
    viewObj		    50
    ssIdHighWaterMark	    8
    decomposition	    CLUSTER_CHART
    type		    EML_CHART
    chartFileNumber	    4
    disableImplicitCasting  1
    eml {
      name		      "CME"
    }
    firstData		    52
    firstTransition	    58
    firstJunction	    57
  }
  state {
    id			    51
    labelString		    "eML_blk_kernel()"
    position		    [18 64.5 118 66]
    fontSize		    12
    chart		    50
    treeNode		    [50 0 0 0]
    superState		    SUBCHART
    subviewer		    50
    ssIdNumber		    1
    type		    FUNC_STATE
    decomposition	    CLUSTER_STATE
    eml {
      isEML		      1
      script		      "% et: erro (ref-meas)\n% B: Parâmetro 3\n% ur: Parâmetro 2 (batentes do controle)\n% er: Parâmetr"
      "o\nfunction u = CME(et, B, ur, er)\n\n\numin = ur(1); umax = ur(2);\n% Cálculo do erro\n%et = yref - y;\ne = et "
      "/ er;\nif e < -1, e = single(-1);  elseif e > 1, e = single(1); end\n% Cálculo de u\nif abs(e) == 1, ut = e; els"
      "e ss = e - sign(e); ut = sign(ss) * (abs(ss) ^ (2 ^ -B) - 1); end\n% Cálculo da saída\na = (umax - umin) / 2; u "
      "= a * (ut - 1) + umax;\n\nend"
      editorLayout	      "100 M4x1[10 5 700 500]"
    }
  }
