  state {
    id			    117
    labelString		    "eML_blk_kernel()"
    position		    [18 64.5 118 66]
    fontSize		    12
    chart		    116
    treeNode		    [116 0 0 0]
    superState		    SUBCHART
    subviewer		    116
    ssIdNumber		    1
    type		    FUNC_STATE
    decomposition	    CLUSTER_STATE
    eml {
      isEML		      1
      script		      "% ref-meas\nfunction e = Compute_Angular_Error(psi_meas, psi_ref)\n\npsi_meas_ = mod(psi_meas, 2*"
      "pi);\npsi_ref_ = mod(psi_ref, 2*pi);\n\nif(psi_meas_ > psi_ref_)\n    if(abs(2*pi-psi_meas_+psi_ref_) < abs(psi_"
      "ref_-psi_meas_))\n        e = 2*pi-psi_meas_+psi_ref_;\n    else\n        e = psi_ref_ - psi_meas_;\n    end\nel"
      "seif (psi_meas_ < psi_ref_)\n    if(abs(psi_meas_ - psi_ref_) < abs(2*pi-psi_ref_+psi_meas_))\n        e = psi_r"
      "ef_ - psi_meas_;\n    else\n        e = -(psi_meas_ + 2*pi - psi_ref_);\n    end\nelse\n    e = single(0);\nend\n"
      "\nend"
      editorLayout	      "100 M4x1[10 5 700 500]"
    }
  }
